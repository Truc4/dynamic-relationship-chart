# Discord Bot Configuration (for optional import-discord.js)
# Get these values from Discord Developer Portal: https://discord.com/developers/applications

# Your bot's token (never commit the actual .env file!)
DISCORD_TOKEN=your_bot_token_here

# Your Discord server (guild) ID
# Right-click your server name and "Copy Server ID" (Developer Mode must be enabled)
GUILD_ID=your_guild_id_here
